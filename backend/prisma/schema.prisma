generator client {
  provider     = "prisma-client-js"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id                            String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                          String
  code                          String                         @unique
  type                          String
  address                       String?
  phone                         String?
  parent_id                     String?                        @db.Uuid
  created_at                    DateTime                       @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime                       @default(now()) @updatedAt @db.Timestamptz(6)
  agents                        Agent[]
  parent                        Branch?                        @relation("BranchHierarchy", fields: [parent_id], references: [id])
  children                      Branch[]                       @relation("BranchHierarchy")
  department_assignment_cursors department_assignment_cursor[]
  leads                         leads[]
  partners                      partners[]

  @@map("branches")
}

model department {
  id                            String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                          String                         @unique
  code                          String                         @unique
  is_active                     Boolean                        @default(true)
  created_at                    DateTime                       @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime                       @default(now()) @updatedAt @db.Timestamptz(6)
  department_assignment_cursors department_assignment_cursor[]
  department_orders             department_order?
  department_statuses           department_status[]
  leads                         leads[]
  partner_departments           partner_department[]

  @@map("departments")
}

model partner_department {
  partner_id    String     @db.Uuid
  department_id String     @db.Uuid
  is_primary    Boolean    @default(false)
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  department    department @relation(fields: [department_id], references: [id], onDelete: Cascade)
  partners      partners   @relation(fields: [partner_id], references: [id], onDelete: Cascade)

  @@id([partner_id, department_id])
  @@index([department_id, is_active], map: "idx_partner_departments_department_active")
  @@index([partner_id, is_active], map: "idx_partner_departments_partner_active")
  @@map("partner_departments")
}

model department_order {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  department_id String     @unique @db.Uuid
  order_index   Int        @unique
  is_default    Boolean    @default(false)
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  department    department @relation(fields: [department_id], references: [id], onDelete: Cascade)

  @@index([is_active, order_index], map: "idx_department_order_active_order")
  @@map("department_order")
}

model department_status {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  department_id String     @db.Uuid
  key           String
  label         String
  order_index   Int
  is_terminal   Boolean    @default(false)
  is_default    Boolean    @default(false)
  is_active     Boolean    @default(true)
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  department    department @relation(fields: [department_id], references: [id], onDelete: Cascade)

  @@unique([department_id, key])
  @@unique([department_id, order_index])
  @@index([department_id, is_active], map: "idx_department_status_department_active")
  @@map("department_statuses")
}

model department_assignment_cursor {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  branch_id       String     @db.Uuid
  department_id   String     @db.Uuid
  last_partner_id String?    @db.Uuid
  updated_at      DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  branch          Branch     @relation(fields: [branch_id], references: [id], onDelete: Cascade)
  department      department @relation(fields: [department_id], references: [id], onDelete: Cascade)
  last_partner    partners?  @relation("department_assignment_cursor_last_partner", fields: [last_partner_id], references: [id])

  @@unique([branch_id, department_id])
  @@index([last_partner_id], map: "idx_department_assignment_cursor_last_partner")
  @@map("department_assignment_cursors")
}

model announcement_reads {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  announcement_id String?        @db.Uuid
  partner_id      String?        @db.Uuid
  read_at         DateTime?      @default(now()) @db.Timestamptz(6)
  announcements   announcements? @relation(fields: [announcement_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  partners        partners?      @relation(fields: [partner_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([announcement_id, partner_id])
}

model announcements {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title              String
  content            String
  target_audience    String
  users              String[]             @default([])
  branch_id          String?
  created_by         String?              @db.Uuid
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  is_active          Boolean?             @default(true)
  branches           String[]             @default([])
  roles              String[]             @default([])
  announcement_reads announcement_reads[]
  partners           partners?            @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model application_documents {
  id                         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id             String       @db.Uuid
  profile_photo_url          String?
  passport_copy_url          String?
  academic_documents_urls    String[]     @default([])
  english_test_cert_url      String?
  sop_url                    String?
  cv_resume_url              String?
  recommendation_letters_url String[]     @default([])
  financial_documents_url    String?
  other_documents_url        String?
  applications               applications @relation(fields: [application_id], references: [id], onDelete: Cascade)
}

model application_family_details {
  id                       String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id           String       @db.Uuid
  father_name              String?
  mother_name              String?
  emergency_contact_name   String?
  emergency_contact_number String?
  applications             applications @relation(fields: [application_id], references: [id], onDelete: Cascade)
}

model application_preferences {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id        String       @db.Uuid
  preferred_country     String?
  preferred_course_type String?
  preferred_course_name String?
  preferred_intake      String?
  preferred_university  String?
  backup_country        String?
  study_mode            String?
  budget_range          String?
  scholarship_interest  Boolean?
  travel_history        String?
  course_id             String?
  applications          applications @relation(fields: [application_id], references: [id], onDelete: Cascade)
  course                Course?      @relation(fields: [course_id], references: [id])
}

model applications {
  id                String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id           String                        @db.Uuid
  student_id        String?                       @unique
  given_name        String?
  surname           String?
  dob               DateTime?                     @db.Date
  gender            String?
  marital_status    String?
  email             String?
  phone             String?
  alternate_phone   String?
  address           String?
  city              String?
  state             String?
  country           String?
  citizenship       String?
  national_id       String?
  current_status    String?
  gap_years         Int?
  referral_source   String?
  application_stage String?
  system_remarks    String?
  created_at        DateTime?                     @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?                     @default(now()) @updatedAt @db.Timestamptz(6)
  documents         application_documents[]
  education         application_education[]
  family_details    application_family_details[]
  financials        ApplicationFinancials?
  preferences       application_preferences[]
  tests             application_tests[]
  visa_details      application_visa_details[]
  work_experience   application_work_experience[]
  leads             leads                         @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  commissions       Commission[]
}

model ApplicationFinancials {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id String          @unique @db.Uuid
  status         FinancialStatus @default(PENDING)
  created_at     DateTime        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  application    applications    @relation(fields: [application_id], references: [id], onDelete: Cascade)
  notes          FinancialNote[]

  @@map("application_financials")
}

model FinancialNote {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  financial_id String                @db.Uuid
  stage        FinancialStatus
  content      String
  created_by   String?               @db.Uuid
  created_at   DateTime              @default(now()) @db.Timestamptz(6)
  partner      partners?             @relation(fields: [created_by], references: [id])
  financials   ApplicationFinancials @relation(fields: [financial_id], references: [id], onDelete: Cascade)

  @@map("financial_notes")
}

model application_education {
  id                    String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id        String       @db.Uuid
  level                 String?
  institution_name      String?
  board_university      String?
  country_of_study      String?
  major_stream          String?
  percentage_gpa        String?
  year_of_passing       String?
  medium_of_instruction String?
  backlogs              Int?
  certificate_url       String?
  applications          applications @relation(fields: [application_id], references: [id], onDelete: Cascade)
}

model application_tests {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id String       @db.Uuid
  test_type      String?
  test_date      DateTime?    @db.Date
  overall_score  Decimal?     @db.Decimal(4, 1)
  listening      Decimal?     @db.Decimal(4, 1)
  reading        Decimal?     @db.Decimal(4, 1)
  writing        Decimal?     @db.Decimal(4, 1)
  speaking       Decimal?     @db.Decimal(4, 1)
  trf_number     String?
  applications   applications @relation(fields: [application_id], references: [id], onDelete: Cascade)
}

model application_work_experience {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id  String       @db.Uuid
  company_name    String?
  designation     String?
  start_date      DateTime?    @db.Date
  end_date        DateTime?    @db.Date
  job_duties      String?
  certificate_url String?
  applications    applications @relation(fields: [application_id], references: [id], onDelete: Cascade)
}

model application_visa_details {
  id                      String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  application_id          String       @db.Uuid
  passport_number         String?
  passport_issue_date     DateTime?    @db.Date
  passport_expiry_date    DateTime?    @db.Date
  passport_place_of_issue String?
  passport_nationality    String?
  country_applied_for     String?
  previous_visa_type      String?
  visa_status             String?
  visa_refusal_reason     String?
  travelled_countries     String?
  is_visa_rejected_past   Boolean?
  applications            applications @relation(fields: [application_id], references: [id], onDelete: Cascade)
}

model followup_comments {
  id          BigInt     @id @default(autoincrement())
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  text        String?
  followup_id String?    @db.Uuid
  created_by  String?    @db.Uuid
  partners    partners?  @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  followups   followups? @relation(fields: [followup_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model followups {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at        DateTime            @db.Timestamptz(6)
  title             String?
  lead_id           String?             @db.Uuid
  completed         Boolean?
  created_by        String?             @db.Uuid
  due_date          DateTime?           @db.Timestamptz(6)
  followup_comments followup_comments[]
  partners          partners?           @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leads             leads?              @relation(fields: [lead_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model leads {
  id                                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                                 String
  email                                String             @unique
  mobile                               String             @unique
  type                                 String
  preferred_country                    String
  preferred_course                     String?
  status                               String
  utm_source                           String?
  utm_medium                           String?
  utm_campaign                         String?
  assigned_to                          String?            @db.Uuid
  created_at                           DateTime           @default(now()) @db.Timestamptz(6)
  created_by                           String?            @db.Uuid
  reason                               String?
  password                             String?            @default("")
  is_flagged                           Boolean            @default(false)
  branch_id                            String?            @db.Uuid
  agent_id                             String?            @db.Uuid
  assigned_agent_id                    String?            @db.Uuid
  agent_team_member_id                 String?            @db.Uuid
  exam_score                           String?
  exam_taken                           String?
  current_department_id                String?            @db.Uuid
  past_departments                     Json               @default("[]")
  past_owners                          Json               @default("[]")
  applications                         applications[]
  chat_messages                        ChatMessage[]
  commissions                          Commission[]
  followups                            followups[]
  agent                                Agent?             @relation(fields: [agent_id], references: [id])
  agent_team_member                    AgentTeamMember?   @relation(fields: [agent_team_member_id], references: [id])
  assigned_agent                       Agent?             @relation("LegacyAssignedAgent", fields: [assigned_agent_id], references: [id])
  partners_leads_assigned_toTopartners partners?          @relation("leads_assigned_toTopartners", fields: [assigned_to], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branch                               Branch?            @relation(fields: [branch_id], references: [id])
  partners_leads_created_byTopartners  partners?          @relation("leads_created_byTopartners", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  current_department                   department?        @relation(fields: [current_department_id], references: [id])
  notes                                notes[]
  offline_payments                     offline_payments[]
  timeline                             timeline[]
  courses                              Course[]           @relation("LeadCourses")

  @@index([branch_id, current_department_id], map: "idx_leads_branch_department")
  @@index([current_department_id], map: "idx_leads_department")
}

model notes {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  text       String?
  lead_id    String?   @db.Uuid
  created_by String?   @db.Uuid
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  partners   partners? @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leads      leads?    @relation(fields: [lead_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model offline_payments {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_mode String?
  currency     String
  amount       BigInt?
  payment_type String
  reference_id String?
  receiver     String?   @db.Uuid
  lead_id      String?   @db.Uuid
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  status       String?
  file         String?
  created_by   String?   @db.Uuid
  due_date     DateTime? @db.Timestamptz(6)
  creator      partners? @relation("offline_payments_creator", fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  leads        leads?    @relation(fields: [lead_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  partners     partners? @relation("offline_payments_receiver", fields: [receiver], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model partners {
  id                                String                         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id                           String                         @db.Uuid
  name                              String
  email                             String                         @unique
  mobile                            String                         @unique
  password                          String
  address                           String
  city                              String
  state                             String
  area                              String
  zone                              String
  remarks                           String?
  agency_name                       String?
  created_at                        DateTime                       @default(now()) @db.Timestamptz(6)
  branch_id                         String?                        @db.Uuid
  announcement_reads                announcement_reads[]
  announcements                     announcements[]
  sent_messages                     ChatMessage[]
  last_assignment_cursors           department_assignment_cursor[] @relation("department_assignment_cursor_last_partner")
  financial_notes                   FinancialNote[]
  followup_comments                 followup_comments[]
  followups                         followups[]
  leads_leads_assigned_toTopartners leads[]                        @relation("leads_assigned_toTopartners")
  leads_leads_created_byTopartners  leads[]                        @relation("leads_created_byTopartners")
  notes                             notes[]
  recorded_payments                 offline_payments[]             @relation("offline_payments_creator")
  received_payments                 offline_payments[]             @relation("offline_payments_receiver")
  partner_departments               partner_department[]
  branch                            Branch?                        @relation(fields: [branch_id], references: [id])
  role                              role                           @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  support_tickets                   SupportTicket[]                @relation("LegacySupportTicketPartner")
  requested_support_tickets         SupportTicket[]                @relation("SupportTicketRequesterPartner")
  timeline                          timeline[]
  todos                             todos[]
}

model Agent {
  id                         String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                      String                  @unique
  mobile                     String                  @unique
  password                   String
  name                       String
  agency_name                String
  website                    String?
  region                     String
  country                    String
  state                      String
  city                       String
  address                    String
  postal_code                String?
  business_reg_no            String?
  established_year           Int?
  status                     AgentStatus             @default(PENDING)
  is_active                  Boolean                 @default(true)
  rejection_reason           String?
  created_at                 DateTime                @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                @default(now()) @updatedAt @db.Timestamptz(6)
  branch_id                  String?                 @db.Uuid
  agent_role                 AgentRole?              @default(OWNER)
  parent_id                  String?                 @db.Uuid
  contract_approved          Boolean                 @default(false)
  contracts                  AgentContract[]
  documents                  AgentDocument[]
  team_members               AgentTeamMember[]
  university_access          AgentUniversityAccess[]
  branch                     Branch?                 @relation(fields: [branch_id], references: [id])
  parent_agent               Agent?                  @relation("LegacyAgentHierarchy", fields: [parent_id], references: [id])
  child_agents               Agent[]                 @relation("LegacyAgentHierarchy")
  sent_messages              ChatMessage[]
  commissions                Commission[]
  leads                      leads[]
  legacy_assigned_leads      leads[]                 @relation("LegacyAssignedAgent")
  requested_support_tickets  SupportTicket[]         @relation("SupportTicketRequesterAgent")
  team_scope_support_tickets SupportTicket[]         @relation("SupportTicketRequesterParentAgent")

  category_id      String?         @db.Uuid
  category         AgentCategory?  @relation(fields: [category_id], references: [id])

  @@map("agents")
}

model AgentCategory {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String   @unique          // "A", "B", "C"
  label             String?                   // Display name e.g. "Premium Partners"
  description       String?
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  university_access CategoryUniversityAccess[]
  agents            Agent[]

  @@map("agent_categories")
}

model CategoryUniversityAccess {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category_id       String   @db.Uuid
  university_id     String
  commission_percent Decimal  @db.Decimal(5, 2)  // e.g. 15.00%
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  category          AgentCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  university        University    @relation(fields: [university_id], references: [id], onDelete: Cascade)

  @@unique([category_id, university_id])
  @@map("category_university_access")
}

model AgentDocument {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id    String   @db.Uuid
  title       String
  file_url    String
  uploaded_at DateTime @default(now()) @db.Timestamptz(6)
  is_verified Boolean  @default(false)
  agent       Agent    @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@map("agent_documents")
}

model AgentUniversityAccess {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id      String     @db.Uuid
  university_id String
  granted_at    DateTime   @default(now()) @db.Timestamptz(6)
  agent         Agent      @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  university    University @relation(fields: [university_id], references: [id], onDelete: Cascade)

  @@unique([agent_id, university_id])
  @@map("agent_university_access")
}

model AgentContract {
  id             String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id       String?             @db.Uuid
  signature_url  String?
  signed_at      DateTime?           @db.Timestamptz(6)
  approved_at    DateTime?           @db.Timestamptz(6)
  approved_by    String?             @db.Uuid
  content        String
  created_at     DateTime            @default(now()) @db.Timestamptz(6)
  is_signed      Boolean             @default(false)
  rejection_note String?
  status         AgentContractStatus @default(PENDING)
  title          String
  updated_at     DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  agent          Agent?              @relation(fields: [agent_id], references: [id], onDelete: Cascade)

  @@map("agent_contracts")
}

model AgentTeamMember {
  id                        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agent_id                  String          @db.Uuid
  name                      String
  email                     String          @unique
  mobile                    String          @unique
  password                  String
  is_active                 Boolean         @default(true)
  created_at                DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  agent                     Agent           @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  leads                     leads[]
  requested_support_tickets SupportTicket[] @relation("SupportTicketRequesterTeamMember")

  @@map("agent_team_members")
}

model AgentInquiry {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  email            String
  mobile           String
  company_name     String?
  website          String?
  country          String?
  city             String?
  experience_years Int?
  student_volume   String?
  message          String?
  status           InquiryStatus @default(NEW)
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  updated_at       DateTime      @default(now()) @updatedAt @db.Timestamptz(6)

  // New fields for enhanced onboarding
  company_address  String?
  contact_person   String?
  contact_designation String?
  contact_department  String?
  source_country   String?
  operation_countries String?
  phone            String?
  accreditation_details String?
  associations     String?
  moe_approvals    String?

  documents        AgentInquiryDocument[]

  @@map("agent_inquiries")
}

model AgentInquiryDocument {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  inquiry_id  String   @db.Uuid
  label       String   
  file_url    String
  uploaded_at DateTime @default(now()) @db.Timestamptz(6)
  inquiry     AgentInquiry @relation(fields: [inquiry_id], references: [id], onDelete: Cascade)

  @@map("agent_inquiry_documents")
}

model timeline {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id    String         @db.Uuid
  event_type timeline_event
  old_state  String?
  new_state  String?
  created_by String?        @db.Uuid
  created_at DateTime       @default(now()) @db.Timestamptz(6)
  source     String?
  actor_name String?
  partners   partners?      @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  leads      leads          @relation(fields: [lead_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([created_at(sort: Desc)], map: "idx_timeline_created_at")
  @@index([created_by], map: "idx_timeline_created_by")
  @@index([event_type], map: "idx_timeline_event_type")
  @@index([lead_id], map: "idx_timeline_lead_id")
}

model Commission {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id        String?          @db.Uuid
  application_id String?          @db.Uuid
  agent_id       String?          @db.Uuid
  amount         Decimal          @db.Decimal(10, 2)
  currency       String           @default("INR")
  status         CommissionStatus @default(PENDING)
  remarks        String?
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  updated_at     DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  agent          Agent?           @relation(fields: [agent_id], references: [id])
  application    applications?    @relation(fields: [application_id], references: [id])
  lead           leads?           @relation(fields: [lead_id], references: [id])

  @@map("commissions")
}

model permission_group {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @unique
  permissions permission[]
}

model permission {
  id                  String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String            @unique
  permission_group_id String?           @db.Uuid
  permission_group    permission_group? @relation(fields: [permission_group_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  role_permissions    role_permission[]
}

model role {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String            @unique
  description      String?
  partners         partners[]
  role_permissions role_permission[]
}

model role_permission {
  role_id       String     @db.Uuid
  permission_id String     @db.Uuid
  permission    permission @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  role          role       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([role_id, permission_id])
}

model Country {
  id           String       @id @default(uuid())
  name         String       @unique
  flag         String?
  region       String?
  universities University[]

  @@map("countries")
}

model University {
  id                 String                  @id @default(uuid())
  name               String
  logo               String?
  city               String?
  countryId          String                  @map("country_id")
  commission_type    CommissionType?         @default(PERCENTAGE)
  commission_value   Decimal?                @db.Decimal(10, 2)
  currency           String?                 @default("INR")
  excluded_countries String[]                @default([])
  allowed_countries  String[]                @default([])
  agent_access       AgentUniversityAccess[]
  category_access    CategoryUniversityAccess[]
  courses            Course[]
  country            Country                 @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@map("universities")
}

model Course {
  id                      String                    @id @default(uuid())
  name                    String
  description             String?
  level                   String?
  category                String?
  duration                Int?
  feeType                 String?                   @map("fee_type")
  originalFee             Decimal?                  @map("original_fee") @db.Decimal(10, 2)
  feeCurrency             String?                   @default("PLN") @map("fee_currency")
  fee                     Decimal?                  @map("fee") @db.Decimal(10, 2)
  courseCurrency          String?                   @default("PLN") @map("course_currency")
  applicationFee          Decimal?                  @map("application_fee") @db.Decimal(10, 2)
  applicationCurrency     String?                   @default("PLN") @map("application_currency")
  intakeMonth             String?                   @map("intake_month")
  commissionType          String?                   @default("%") @map("commission_type")
  commissionValue         Decimal?                  @map("commission_value") @db.Decimal(10, 2)
  details                 Json?
  universityId            String                    @map("university_id")
  createdAt               DateTime                  @default(now()) @map("created_at")
  excluded_countries      String[]                  @default([])
  application_preferences application_preferences[]
  university              University                @relation(fields: [universityId], references: [id], onDelete: Cascade)
  leads                   leads[]                   @relation("LeadCourses")

  @@map("courses")
}

model todos {
  title      String
  created_by String    @db.Uuid
  completed  Boolean   @default(false)
  dueDate    DateTime?
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  partners   partners  @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model OptionList {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key        String   @unique
  value      Json     @default("{}")
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("option_lists")
}

model ChatMessage {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lead_id     String     @db.Uuid
  partner_id  String?    @db.Uuid
  agent_id    String?    @db.Uuid
  sender_type SenderType
  message     String
  is_read     Boolean    @default(false)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  agent       Agent?     @relation(fields: [agent_id], references: [id])
  lead        leads      @relation(fields: [lead_id], references: [id], onDelete: Cascade)
  partner     partners?  @relation(fields: [partner_id], references: [id])

  @@index([lead_id])
  @@map("chat_messages")
}

model DropdownCategory {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String           @unique
  label      String?
  is_system  Boolean          @default(false)
  created_at DateTime         @default(now()) @db.Timestamptz(6)
  updated_at DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  options    DropdownOption[]

  @@map("dropdown_categories")
}

model DropdownOption {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  label       String
  value       String
  category_id String           @db.Uuid
  is_active   Boolean          @default(true)
  created_at  DateTime         @default(now()) @db.Timestamptz(6)
  category    DropdownCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@map("dropdown_options")
}

model SupportTicket {
  id                        String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  case_number               Int                    @default(autoincrement())
  partner_id                String?                @db.Uuid
  topic                     String
  category                  String
  institution_id            String?
  subject                   String
  description               String
  priority                  TicketPriority         @default(MEDIUM)
  status                    TicketStatus           @default(OPEN)
  attachment_urls           String[]               @default([])
  created_at                DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  requester_agent_id        String?                @db.Uuid
  requester_parent_agent_id String?                @db.Uuid
  requester_partner_id      String?                @db.Uuid
  requester_team_member_id  String?                @db.Uuid
  requester_type            TicketRequesterType?
  comments                  SupportTicketComment[]
  partner                   partners?              @relation("LegacySupportTicketPartner", fields: [partner_id], references: [id])
  requester_agent           Agent?                 @relation("SupportTicketRequesterAgent", fields: [requester_agent_id], references: [id])
  requester_parent_agent    Agent?                 @relation("SupportTicketRequesterParentAgent", fields: [requester_parent_agent_id], references: [id])
  requester_partner         partners?              @relation("SupportTicketRequesterPartner", fields: [requester_partner_id], references: [id])
  requester_team_member     AgentTeamMember?       @relation("SupportTicketRequesterTeamMember", fields: [requester_team_member_id], references: [id])

  @@index([requester_type, requester_partner_id], map: "idx_support_tickets_req_partner")
  @@index([requester_type, requester_agent_id], map: "idx_support_tickets_req_agent")
  @@index([requester_type, requester_team_member_id], map: "idx_support_tickets_req_team_member")
  @@index([requester_parent_agent_id], map: "idx_support_tickets_req_parent_agent")
  @@index([status, created_at(sort: Desc)], map: "idx_support_tickets_status_created")
  @@map("support_tickets")
}

model SupportTicketComment {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id       String        @db.Uuid
  sender_id       String        @db.Uuid
  sender_type     String
  sender_name     String
  message         String
  attachment_urls String[]      @default([])
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  ticket          SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@map("support_ticket_comments")
}

model EmailTemplate {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  subject     String
  body        String   @db.Text
  category    String?  // Folder/Purpose category e.g. "Credentials", "Inquiry", "Campaign"
  variables   String[] // List of supported variables for this template
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("email_templates")
}

model IntegrationConfig {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider     IntegrationProvider @unique
  display_name String
  api_key      String?
  api_secret   String?
  config_json  Json?               @default("{}")
  is_active    Boolean             @default(false)
  connected_at DateTime?           @db.Timestamptz(6)
  created_at   DateTime            @default(now()) @db.Timestamptz(6)
  updated_at   DateTime            @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("integration_configs")
}

